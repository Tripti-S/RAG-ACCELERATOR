# ============================================================================
# Week 5: Production RAG — Environment Variables
# ============================================================================
#
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# Required credentials are marked with [REQUIRED].
# Optional settings have defaults that work out of the box.
# ============================================================================

# --- Qdrant Cloud [REQUIRED] ---
# Get credentials from: https://cloud.qdrant.io/
QDRANT_URL=https://your-cluster.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=week3_hybrid_recursive

# --- Google Gemini [REQUIRED] ---
# Get API key from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key
LLM_MODEL=gemini-2.5-flash
LLM_FALLBACK_MODEL=gemini-2.5-flash-lite

# --- Voyage AI [REQUIRED] ---
# Get API key from: https://dash.voyageai.com/
VOYAGE_API_KEY=your_voyage_api_key
VOYAGE_EMBED_MODEL=voyage-4-lite
VOYAGE_DIMENSION=2048

# --- Redis Cloud [REQUIRED] ---
# Get credentials from: https://cloud.redis.io/
# Free tier works fine for development
REDIS_HOST=your-redis-host.cloud.redislabs.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_USERNAME=default
REDIS_SSL=true

# --- Sparse Embeddings ---
SPARSE_MODEL=Qdrant/bm25

# --- Semantic Cache ---
CACHE_EMBED_MODEL=voyage-4-lite
CACHE_EMBED_DIMENSION=2048
CACHE_DISTANCE_THRESHOLD=0.06
CACHE_TTL=86400

# --- Conversation Memory ---
CONVERSATION_WINDOW_SIZE=10
CONVERSATION_SESSION_TTL=86400

# --- Opik Observability (optional) ---
# Get API key from: https://www.comet.com/opik
# OPIK_API_KEY=your_opik_api_key
# OPIK_WORKSPACE=your_workspace
# OPIK_PROJECT_NAME=rag-accelerator-prod

# --- Application ---
APP_NAME=RAG Accelerator - Production
DEBUG=false

# --- macOS gRPC Fix ---
# Uncomment if you get DNS resolution errors with Qdrant
# GRPC_DNS_RESOLVER=native
